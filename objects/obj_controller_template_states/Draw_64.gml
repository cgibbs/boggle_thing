draw_set_color(c_black);
draw_text_ext(20, 20,	"-- Template States & Injected State Code Example --\n" +
						"Press A and D to move and space to jump.\n\n" +
						"Whenever you enter the movement state, you should see console messages that indicate the addition of new code to the movement state printed from the movement state template, plus the ordering that code executes in.\n\n" +
						"Press enter to move to the next room.", -1, 550);